{
  "name": "familie-ba-minside-mikrofrontend",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "prepare": "husky",
    "lint": "eslint './src/**/*.{js,ts,tsx}'",
    "lint:fix": "eslint './src/**/*.{js,ts,tsx}' --fix",
    "prettier": "prettier --plugin=prettier-plugin-astro --check './src/**/*.{js,jsx,ts,tsx,json,css,astro}'",
    "prettier:fix": "prettier --plugin=prettier-plugin-astro --write './src/**/*.{js,jsx,ts,tsx,json,css,astro}'",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "",
    "validate": "yarn typecheck && yarn lint && yarn prettier"
  },
  "dependencies": {
    "@astrojs/check": "0.9.6",
    "@astrojs/node": "9.5.4",
    "@astrojs/react": "5.0.0",
    "@navikt/aksel-icons": "7.38.0",
    "@navikt/ds-css": "7.38.0",
    "@navikt/ds-react": "7.38.0",
    "@navikt/oasis": "4.1.1",
    "@opentelemetry/sdk-node": "0.212.0",
    "astro": "5.18.0",
    "pino": "10.3.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rollup-plugin-import-map": "3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@types/node": "24.11.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "husky": "9.1.7",
    "lint-staged": "16.3.1",
    "postcss": "8.5.8",
    "postcss-prefix-selector": "2.1.1",
    "prettier": "3.8.1",
    "prettier-plugin-astro": "0.14.1",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc,astro,css,md,html}": [
      "prettier --plugin=prettier-plugin-astro --check './src/**/*.{js,jsx,ts,tsx,json,css,astro}'",
      "eslint --max-warnings=30"
    ]
  }
}
